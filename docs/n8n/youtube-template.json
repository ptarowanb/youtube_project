{
  "name": "YouTube Research Approval Production Template",
  "meta": {
    "instanceId": "youtube-project-single-import-template"
  },
  "nodes": [
    {
      "id": "yt-001",
      "name": "Scheduled Daily Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [
        240,
        220
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 9,
              "triggerAtMinute": 0
            }
          ]
        }
      },
      "typeVersion": 1.3
    },
    {
      "id": "yt-002",
      "name": "Compute Lookback",
      "type": "n8n-nodes-base.code",
      "position": [
        460,
        220
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const since = new Date(Date.now() - 3 * 24 * 60 * 60 * 1000).toISOString(); return [{ json: { published_after: since } }];"
      },
      "typeVersion": 2
    },
    {
      "id": "yt-003",
      "name": "Read Channels in Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "position": [
        700,
        100
      ],
      "parameters": {
        "documentId": {
          "__rl": true,
          "mode": "list",
          "value": "YOUR_SPREADSHEET_ID"
        },
        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "gid=0",
          "cachedResultName": "channels"
        },
        "authentication": "serviceAccount",
        "options": {}
      },
      "typeVersion": 4.7
    },
    {
      "id": "yt-004",
      "name": "Filter Enabled Channels",
      "type": "n8n-nodes-base.code",
      "position": [
        920,
        100
      ],
      "parameters": {
        "jsCode": "return items.filter((item) => { const enabled = item.json.enabled; const channelId = item.json.channel_id || item.json.channelId; const isEnabled = enabled === true || enabled === 1 || enabled === '1' || String(enabled).toLowerCase() === 'true'; return isEnabled && Boolean(channelId); });"
      },
      "typeVersion": 2
    },
    {
      "id": "yt-005",
      "name": "Fetch Channel Videos",
      "type": "n8n-nodes-base.youTube",
      "position": [
        1140,
        100
      ],
      "parameters": {
        "resource": "video",
        "returnAll": true,
        "filters": {
          "channelId": "={{$json.channel_id || $json.channelId}}",
          "publishedAfter": "={{$('Compute Lookback').first().json.published_after}}"
        },
        "options": {}
      },
      "credentials": {
        "youTubeOAuth2Api": {
          "id": "credential-id",
          "name": "YouTube OAuth2"
        }
      },
      "typeVersion": 1
    },
    {
      "id": "yt-006",
      "name": "Normalize Harvested Videos",
      "type": "n8n-nodes-base.code",
      "position": [
        1360,
        100
      ],
      "parameters": {
        "jsCode": "return items.map(item => ({ json: { video_id: item.json.id, channel_id: item.json.snippet?.channelId, channel_name: item.json.snippet?.channelTitle, title: item.json.snippet?.title, url: `https://www.youtube.com/watch?v=${item.json.id}`, published_at: item.json.snippet?.publishedAt, harvested_at: new Date().toISOString(), status: 'new', _source: 'harvested' } }));"
      },
      "typeVersion": 2
    },
    {
      "id": "yt-007",
      "name": "Read source_videos",
      "type": "n8n-nodes-base.googleSheets",
      "position": [
        700,
        360
      ],
      "parameters": {
        "documentId": {
          "__rl": true,
          "mode": "list",
          "value": "YOUR_SPREADSHEET_ID"
        },
        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "gid=1",
          "cachedResultName": "source_videos"
        },
        "authentication": "serviceAccount",
        "options": {}
      },
      "typeVersion": 4.7
    },
    {
      "id": "yt-008",
      "name": "Mark Existing Videos",
      "type": "n8n-nodes-base.code",
      "position": [
        920,
        360
      ],
      "parameters": {
        "jsCode": "return items.map(item => ({ json: { ...item.json, _source: 'existing' } }));"
      },
      "typeVersion": 2
    },
    {
      "id": "yt-009",
      "name": "Merge Harvested and Existing Videos",
      "type": "n8n-nodes-base.merge",
      "position": [
        1580,
        220
      ],
      "parameters": {},
      "typeVersion": 3.2
    },
    {
      "id": "yt-010",
      "name": "Deduplicate Against source_videos",
      "type": "n8n-nodes-base.code",
      "position": [
        1800,
        220
      ],
      "parameters": {
        "jsCode": "const existing = new Set(items.filter(item => item.json._source === 'existing').map(item => item.json.video_id).filter(Boolean)); const seen = new Set(); return items.filter(item => item.json._source === 'harvested').filter(item => { const id = item.json.video_id; if (!id || existing.has(id) || seen.has(id)) return false; seen.add(id); return true; }).map(item => { const { _source, ...json } = item.json; return { json }; });"
      },
      "typeVersion": 2
    },
    {
      "id": "yt-011",
      "name": "Append New Videos to source_videos",
      "type": "n8n-nodes-base.googleSheets",
      "position": [
        2020,
        220
      ],
      "parameters": {
        "operation": "append",
        "authentication": "serviceAccount",
        "documentId": {
          "__rl": true,
          "mode": "list",
          "value": "YOUR_SPREADSHEET_ID"
        },
        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "gid=1",
          "cachedResultName": "source_videos"
        },
        "columns": {
          "mappingMode": "autoMapInputData",
          "value": null
        },
        "options": {}
      },
      "typeVersion": 4.7
    },
    {
      "id": "yt-012",
      "name": "Gemini Idea Analyzer",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "position": [
        2240,
        220
      ],
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "__rl": true,
          "mode": "id",
          "value": "models/gemini-2.5-flash"
        },
        "messages": {
          "values": [
            {
              "role": "user",
              "content": "=Analyze this source video for a safe, original Korean Shorts idea. Return JSON only with: topic, hook, angle, summary, suggested_title, suggested_description, suggested_tags. Channel: {{$json.channel_name}}. Source title: {{$json.title}}. Source URL: {{$json.url}}. Do not suggest reusing original footage."
            }
          ]
        },
        "jsonOutput": true,
        "simplify": false,
        "builtInTools": {},
        "options": {
          "systemMessage": "Output valid JSON only.",
          "temperature": 0.7,
          "maxOutputTokens": 1000,
          "thinkingBudget": 0
        }
      },
      "credentials": {
        "googlePalmApi": {
          "id": "credential-id",
          "name": "Google Gemini Credential"
        }
      },
      "typeVersion": 1.1
    },
    {
      "id": "yt-013",
      "name": "Parse Idea",
      "type": "n8n-nodes-base.code",
      "position": [
        2460,
        220
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const candidate = $json.candidates?.[0]; const parts = candidate?.content?.parts || []; const textPart = parts.find((part) => typeof part.text === 'string'); if (!textPart?.text) throw new Error('Missing Gemini text output'); const raw = textPart.text.trim().replace(/^```json\\s*/i, '').replace(/^```/i, '').replace(/```$/i, '').trim(); const parsed = JSON.parse(raw); const source = $('Deduplicate Against source_videos').item.json; return [{ json: { idea_id: `idea_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`, source_video_id: source.video_id, channel_name: source.channel_name, topic: parsed.topic, hook: parsed.hook, angle: parsed.angle, summary: parsed.summary, suggested_title: parsed.suggested_title, suggested_description: parsed.suggested_description, suggested_tags: Array.isArray(parsed.suggested_tags) ? parsed.suggested_tags.join(',') : (parsed.suggested_tags || ''), source_url: source.url, status: 'draft', telegram_message_id: '', approved_at: '', review_action: '' } }];",
        "mode": "runOnceForEachItem"
      },
      "typeVersion": 2
    },
    {
      "id": "yt-014",
      "name": "Save Draft Idea",
      "type": "n8n-nodes-base.googleSheets",
      "position": [
        2680,
        220
      ],
      "parameters": {
        "operation": "append",
        "authentication": "serviceAccount",
        "documentId": {
          "__rl": true,
          "mode": "list",
          "value": "YOUR_SPREADSHEET_ID"
        },
        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "gid=2",
          "cachedResultName": "ideas"
        },
        "columns": {
          "mappingMode": "autoMapInputData",
          "value": null
        },
        "options": {}
      },
      "typeVersion": 4.7
    },
    {
      "id": "yt-015",
      "name": "Format Telegram Approval",
      "type": "n8n-nodes-base.code",
      "position": [
        2900,
        220
      ],
      "parameters": {
        "jsCode": "const idea = $json; const telegram_message = [`[Idea] ${idea.idea_id}`, `Channel: ${idea.channel_name}`, `Source: ${idea.source_url}`, `Topic: ${idea.topic}`, `Hook: ${idea.hook}`, `Angle: ${idea.angle}`, `Summary: ${idea.summary}`].join('\\n'); return [{ json: { ...idea, telegram_message } }];",
        "mode": "runOnceForEachItem",
        "language": "javaScript"
      },
      "typeVersion": 2
    },
    {
      "id": "yt-016",
      "name": "Send Telegram Approval",
      "type": "n8n-nodes-base.telegram",
      "position": [
        3120,
        220
      ],
      "webhookId": "telegram-idea-approval-template",
      "parameters": {
        "chatId": "={{$env.TELEGRAM_REVIEW_CHAT_ID}}",
        "text": "={{$json.telegram_message}}",
        "replyMarkup": "inlineKeyboard",
        "inlineKeyboard": {
          "rows": [
            {
              "row": {
                "buttons": [
                  {
                    "text": "Approve",
                    "additionalFields": {
                      "callback_data": "=approve|{{$json.idea_id}}"
                    }
                  },
                  {
                    "text": "Hold",
                    "additionalFields": {
                      "callback_data": "=hold|{{$json.idea_id}}"
                    }
                  },
                  {
                    "text": "Reject",
                    "additionalFields": {
                      "callback_data": "=reject|{{$json.idea_id}}"
                    }
                  }
                ]
              }
            }
          ]
        },
        "additionalFields": {
          "appendAttribution": false
        }
      },
      "credentials": {
        "telegramApi": {
          "id": "credential-id",
          "name": "Telegram Bot Credential"
        }
      },
      "typeVersion": 1.2
    },
    {
      "id": "yt-017",
      "name": "Persist Telegram Message Id",
      "type": "n8n-nodes-base.googleSheets",
      "position": [
        3340,
        220
      ],
      "parameters": {
        "operation": "appendOrUpdate",
        "authentication": "serviceAccount",
        "documentId": {
          "__rl": true,
          "mode": "list",
          "value": "YOUR_SPREADSHEET_ID"
        },
        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "gid=2",
