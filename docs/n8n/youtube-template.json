        "options": {}
      },
      "typeVersion": 4.7
    },
    {
      "id": "yt-024",
      "name": "Approval Is Approve?",
      "type": "n8n-nodes-base.if",
      "position": [
        1560,
        760
      ],
      "parameters": {
        "conditions": {
          "options": {
            "version": 2
          },
          "combinator": "and",
          "conditions": [
            {
              "leftValue": "={{$json.status}}",
              "operator": {
                "type": "string",
                "operation": "equals"
              },
              "rightValue": "approved"
            }
          ]
        },
        "options": {}
      },
      "typeVersion": 2.2
    },
    {
      "id": "yt-025",
      "name": "Build Production Input",
      "type": "n8n-nodes-base.code",
      "position": [
        1780,
        660
      ],
        "parameters": {
          "jsCode": "const now = new Date().toISOString().replace(/[-:.TZ]/g, '').slice(0, 14);\nconst rand = Math.random().toString(36).slice(2, 8);\nconst tags = String($json.suggested_tags || '')\n  .split(',')\n  .map(tag => tag.trim())\n  .filter(Boolean);\n\nconst styleProfiles = {\n  mystery: {\n    style: 'dark mystery shorts',\n    visual_style: 'cinematic noir stills',\n  },\n  emotional: {\n    style: 'warm emotional shorts',\n    visual_style: 'soft cinematic stills',\n  },\n  news: {\n    style: 'fast factual shorts',\n    visual_style: 'clean editorial stills',\n  },\n  knowledge: {\n    style: 'smart educational shorts',\n    visual_style: 'clean educational stills',\n  },\n};\n\nconst styleProfile = $json.style_profile || 'mystery';\nconst selected = styleProfiles[styleProfile] || styleProfiles.mystery;\n\nreturn [{\n  json: {\n    idea_id: $json.idea_id,\n    style_profile: styleProfile,\n    job_id: `yt_${now}_${rand}`,\n    topic: $json.topic || $json.suggested_title || 'Untitled topic',\n    style: selected.style,\n    duration_seconds: 30,\n    voice_id: 'tc_60e5426de8b95f1d3000d7b5',\n    visual_style: selected.visual_style,\n    hook_clip_count: 1,\n    render_bucket_name: $env.RENDER_BUCKET_NAME || 'replace-me-bucket',\n    gemini_text_model: 'models/gemini-2.5-flash',\n    gemini_image_model: 'models/gemini-2.5-flash-image',\n    veo_model: 'models/veo-3.1-fast-generate-preview',\n    hook_seed: $json.hook,\n    angle_seed: $json.angle,\n    summary_seed: $json.summary,\n    youtube_title: $json.suggested_title || $json.topic,\n    youtube_description: $json.suggested_description || '',\n    youtube_tags: tags,\n    youtube_privacy_status: 'private',\n    bgm_key: 'shared/bgm/default.mp3'\n  }\n}];",
          "mode": "runOnceForEachItem",
          "language": "javaScript"
        },
      "typeVersion": 2
    },
    {
      "id": "yt-026",
      "name": "Gemini Scenario Planner",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "position": [
        2000,
        660
      ],
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "__rl": true,
          "mode": "id",
          "value": "={{$json.gemini_text_model}}"
        },
        "messages": {
          "values": [
            {
              "role": "user",
              "content": "=Create a Shorts production plan from this approved idea. Return JSON only with: scenario_title, youtube_title, youtube_description, youtube_tags, narration_script, hook_video_prompts, still_image_prompts. Topic: {{$('Build Production Input').first().json.topic}}. Hook seed: {{$('Build Production Input').first().json.hook_seed}}. Angle seed: {{$('Build Production Input').first().json.angle_seed}}. Summary seed: {{$('Build Production Input').first().json.summary_seed}}. Keep one still image prompt and one hook video prompt."
            }
          ]
        },
        "jsonOutput": true,
        "simplify": false,
        "builtInTools": {},
        "options": {
          "systemMessage": "Output valid JSON only.",
          "temperature": 0.7,
          "maxOutputTokens": 1500,
          "thinkingBudget": 0
        }
      },
      "credentials": {
        "googlePalmApi": {
          "id": "credential-id",
          "name": "Google Gemini Credential"
        }
      },
      "typeVersion": 1.1
    },
    {
      "id": "12b6b52c-9880-4653-b7eb-c6ee7b310006",
      "name": "Parse Scenario",
      "type": "n8n-nodes-base.code",
      "position": [
        2272,
        660
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "const response = $json;\nconst candidate = response.candidates?.[0];\nconst parts = candidate?.content?.parts || [];\nconst textPart = parts.find((part) => typeof part.text === 'string');\nif (!textPart?.text) {\n  throw new Error('Gemini scenario response did not include text output');\n}\nconst raw = textPart.text.trim().replace(/^```json\\s*/i, '').replace(/^```/i, '').replace(/```$/i, '').trim();\nconst parsed = JSON.parse(raw);\nconst input = $('Build Production Input').first().json;\nconst hookVideoPrompts = Array.isArray(parsed.hook_video_prompts) ? parsed.hook_video_prompts : [];\nconst stillImagePrompts = Array.isArray(parsed.still_image_prompts) ? parsed.still_image_prompts : [];\n\nreturn [{\n  json: {\n    ...input,\n    scenario_title: parsed.scenario_title || input.topic,\n    youtube_title: parsed.youtube_title || input.youtube_title,\n    youtube_description: parsed.youtube_description || input.youtube_description,\n    youtube_tags: parsed.youtube_tags || input.youtube_tags,\n    narration_script: parsed.narration_script || input.topic,\n    hook_video_prompt: hookVideoPrompts[0] || (input.topic + ' vertical cinematic hook shot'),\n    still_image_prompt: stillImagePrompts[0] || (input.topic + ' cinematic still frame')\n  }\n}];"
      },
      "typeVersion": 2
    },
    {
      "id": "ae619bf1-6022-4fd6-aa85-5ca4d9f10007",
      "name": "Typecast Narration",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        2544,
        660
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.typecast.ai/v1/text-to-speech",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-KEY",
              "value": "={{$env.TYPECAST_API_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ ({\n  voice_id: $('Parse Scenario').first().json.voice_id,\n  text: $('Parse Scenario').first().json.narration_script,\n  model: 'ssfm-v30',\n  language: 'kor',\n  prompt: {\n    emotion_type: 'smart'\n  },\n  output: {\n    volume: 100,\n    audio_pitch: 0,\n    audio_tempo: 1,\n    audio_format: 'mp3'\n  }\n}) }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file",
              "outputPropertyName": "narration"
            }
          }
        }
      },
