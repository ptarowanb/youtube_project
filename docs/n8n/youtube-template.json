        },
        "columns": {
          "mappingMode": "autoMapInputData",
          "matchingColumns": [
            "idea_id"
          ],
          "value": {
            "idea_id": "={{$('Format Telegram Approval').item.json.idea_id}}",
            "source_video_id": "={{$('Format Telegram Approval').item.json.source_video_id}}",
            "channel_name": "={{$('Format Telegram Approval').item.json.channel_name}}",
            "topic": "={{$('Format Telegram Approval').item.json.topic}}",
            "hook": "={{$('Format Telegram Approval').item.json.hook}}",
            "angle": "={{$('Format Telegram Approval').item.json.angle}}",
            "summary": "={{$('Format Telegram Approval').item.json.summary}}",
              "suggested_title": "={{$('Format Telegram Approval').item.json.suggested_title}}",
              "suggested_description": "={{$('Format Telegram Approval').item.json.suggested_description}}",
              "suggested_tags": "={{$('Format Telegram Approval').item.json.suggested_tags}}",
              "style_profile": "={{$('Format Telegram Approval').item.json.style_profile}}",
              "source_url": "={{$('Format Telegram Approval').item.json.source_url}}",
              "status": "={{$('Format Telegram Approval').item.json.status}}",
              "telegram_message_id": "={{$json.message_id || $json.result?.message_id || ''}}",
            "approved_at": "={{$('Format Telegram Approval').item.json.approved_at}}",
            "review_action": "={{$('Format Telegram Approval').item.json.review_action}}"
          }
        },
        "options": {}
      },
      "typeVersion": 4.7
    },
    {
      "id": "yt-018",
      "name": "Telegram Callback Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "position": [
        240,
        760
      ],
      "webhookId": "telegram-approval-callback-template",
      "parameters": {
        "updates": [
          "callback_query"
        ],
        "additionalFields": {}
      },
