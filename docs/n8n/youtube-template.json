    },
    {
      "id": "yt-019",
      "name": "Parse Approval Callback",
      "type": "n8n-nodes-base.code",
      "position": [
        460,
        760
      ],
      "parameters": {
        "jsCode": "const callback = $json.callback_query; if (!callback?.data) throw new Error('Missing callback query data'); const [action, idea_id] = callback.data.split('|'); return [{ json: { action, idea_id, chat_id: callback.message?.chat?.id, message_id: callback.message?.message_id, callback_query_id: callback.id } }];",
        "mode": "runOnceForEachItem",
        "language": "javaScript"
      },
      "typeVersion": 2
    },
    {
      "id": "yt-020",
      "name": "Read Ideas Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "position": [
        680,
        760
      ],
      "parameters": {
        "documentId": {
          "__rl": true,
          "mode": "list",
          "value": "YOUR_SPREADSHEET_ID"
        },
        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "gid=2",
          "cachedResultName": "ideas"
        },
        "authentication": "serviceAccount",
        "options": {}
      },
      "typeVersion": 4.7
    },
    {
      "id": "yt-021",
      "name": "Match Callback Idea",
      "type": "n8n-nodes-base.code",
      "position": [
        900,
        760
      ],
      "parameters": {
        "jsCode": "const callback = $('Parse Approval Callback').first().json; const match = items.find(item => item.json.idea_id === callback.idea_id); if (!match) throw new Error(`Idea not found for ${callback.idea_id}`); return [{ json: { ...match.json, ...callback } }];"
      },
      "typeVersion": 2
    },
    {
      "id": "yt-022",
      "name": "Build Review Update",
      "type": "n8n-nodes-base.code",
      "position": [
        1120,
        760
      ],
      "parameters": {
        "jsCode": "const map = { approve: 'approved', hold: 'hold', reject: 'rejected' }; const status = map[$json.action] || 'draft'; return [{ json: { ...$json, status, review_action: $json.action, approved_at: status === 'approved' ? new Date().toISOString() : ($json.approved_at || '') } }];",
        "mode": "runOnceForEachItem",
        "language": "javaScript"
      },
      "typeVersion": 2
    },
    {
      "id": "yt-023",
      "name": "Persist Review State",
      "type": "n8n-nodes-base.googleSheets",
      "position": [
        1340,
        760
      ],
      "parameters": {
        "operation": "appendOrUpdate",
        "authentication": "serviceAccount",
        "documentId": {
          "__rl": true,
          "mode": "list",
          "value": "YOUR_SPREADSHEET_ID"
        },
        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "gid=2",
          "cachedResultName": "ideas"
        },
